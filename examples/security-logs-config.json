{
  "config_key": "security-team:firewall-logs",
  "tenant_id": "security-team",
  "dataset_id": "firewall-logs",
  "enabled": true,
  "version": "1.3.0",
  "description": "Security event processing for firewall and IDS logs",
  "created_at": "2025-09-24T14:30:00Z",
  "updated_at": "2025-09-24T14:30:00Z",
  "updated_by": "security@company.com",
  "validated": true,
  "checksum": "sha256:f1e2d3c4b5a6...",
  "settings": {
    "auto_format_detection": true,
    "drop_parse_failures": false,
    "preserve_raw_on_error": true,
    "compress_output": true,
    "priority": "high"
  },
  "filters": [
    {
      "type": "add_field",
      "name": "security_classification",
      "enabled": true,
      "description": "Mark all records as security events",
      "config": {
        "field": "event_category",
        "value": "security"
      }
    },
    {
      "type": "add_field",
      "name": "severity_mapping",
      "enabled": true,
      "description": "Add severity level based on CEF severity",
      "condition": "if [severity] >= 7",
      "config": {
        "field": "alert_level",
        "value": "critical"
      }
    },
    {
      "type": "conditional",
      "name": "high_severity_filter",
      "enabled": true,
      "description": "Keep only medium to high severity events",
      "config": {
        "field": "severity",
        "operator": "gte",
        "value": 4,
        "action": "keep"
      }
    },
    {
      "type": "add_field",
      "name": "threat_intelligence_placeholder",
      "enabled": false,
      "description": "Add threat intel data (future enhancement)",
      "config": {
        "field": "threat_score",
        "value": "0"
      }
    },
    {
      "type": "rename_field",
      "name": "standardize_ip_fields",
      "enabled": true,
      "description": "Standardize IP field names",
      "config": {
        "from": "src",
        "to": "source_ip"
      }
    },
    {
      "type": "rename_field",
      "name": "standardize_dest_fields",
      "enabled": true,
      "config": {
        "from": "dst",
        "to": "destination_ip"
      }
    },
    {
      "type": "add_field",
      "name": "processing_pipeline",
      "enabled": true,
      "config": {
        "field": "processed_by_pipeline",
        "value": "security-events-v1.3"
      }
    },
    {
      "type": "conditional",
      "name": "internal_traffic_filter",
      "enabled": true,
      "description": "Flag internal network traffic",
      "condition": "if [source_ip] =~ /^10\\.|^172\\.(1[6-9]|2[0-9]|3[01])\\.|^192\\.168\\./",
      "config": {
        "field": "source_ip",
        "operator": "contains",
        "value": "10.",
        "action": "keep"
      }
    },
    {
      "type": "add_field",
      "name": "network_classification",
      "enabled": true,
      "condition": "if [source_ip] =~ /^10\\./",
      "config": {
        "field": "network_zone",
        "value": "internal"
      }
    }
  ],
  "output": {
    "format": "ndjson",
    "compression": "gzip",
    "s3": {
      "bucket": "security-events-prod",
      "key_pattern": "security/${tenant_id}/${dataset_id}/year=${year}/month=${month}/day=${day}/${filename}"
    }
  },
  "monitoring": {
    "enabled": true,
    "alert_on_errors": false,
    "error_threshold": 0.01,
    "sla": {
      "max_processing_time": "30s",
      "availability": "99.9%"
    }
  }
}