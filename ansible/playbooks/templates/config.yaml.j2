# ByteFreezer Piper Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Host: {{ ansible_hostname }}

app:
  name: {{ config.app.name }}
  version: {{ config.app.version }}
  log_level: {{ config.app.log_level }}
  deployment_type: {{ config.app.deployment_type | default('managed') }}

server:
  api_port: {{ config.server.api_port }}

# S3 source configuration (intake bucket from bytefreezer-receiver)
s3_source:
  bucket_name: {{ config.s3_source.bucket_name }}
  region: {{ config.s3_source.region }}
  poll_interval: {{ config.s3_source.poll_interval }}
  endpoint: "{{ bytefreezer_s3_endpoint }}"
  ssl: {{ config.s3_source.ssl | lower }}
  access_key: "{{ bytefreezer_s3_access_key }}"
  secret_key: "{{ bytefreezer_s3_secret_key }}"
  use_iam_role: {{ config.s3_source.use_iam_role | default(false) | lower }}

# S3 destination configuration (piper bucket for bytefreezer-packer)
s3_destination:
  bucket_name: {{ config.s3_destination.bucket_name }}
  region: {{ config.s3_destination.region }}
  endpoint: "{{ bytefreezer_s3_endpoint }}"
  ssl: {{ config.s3_destination.ssl | lower }}
  access_key: "{{ bytefreezer_s3_access_key }}"
  secret_key: "{{ bytefreezer_s3_secret_key }}"
  use_iam_role: {{ config.s3_destination.use_iam_role | default(false) | lower }}

# S3 GeoIP configuration (GeoIP database updates)
s3_geoip:
  bucket_name: {{ config.s3_geoip.bucket_name }}
  region: {{ config.s3_geoip.region }}
  endpoint: "{{ bytefreezer_s3_endpoint }}"
  ssl: {{ config.s3_geoip.ssl | lower }}
  access_key: "{{ bytefreezer_s3_access_key }}"
  secret_key: "{{ bytefreezer_s3_secret_key }}"
  use_iam_role: {{ config.s3_geoip.use_iam_role | default(false) | lower }}

# Processing engine configuration
processing:
  max_concurrent_jobs: {{ config.processing.max_concurrent_jobs }}
  job_timeout_seconds: {{ config.processing.job_timeout_seconds }}
  retry_attempts: {{ config.processing.retry_attempts }}
  retry_backoff: {{ config.processing.retry_backoff }}
  buffer_size: {{ config.processing.buffer_size }}

# Pipeline configuration
pipeline:
  controller_endpoint: "{{ config.pipeline.controller_endpoint }}"
  config_refresh_interval: {{ config.pipeline.config_refresh_interval }}
  geoip_database_path: {{ config.pipeline.geoip_database_path }}
  geoip_city_database: {{ config.pipeline.geoip_city_database }}
  geoip_country_database: {{ config.pipeline.geoip_country_database }}
  enable_geoip: {{ config.pipeline.enable_geoip | lower }}

# Control Service configuration (replaces dev mode and legacy controller)
control_service:
  enabled: {{ config.control_service.enabled | lower }}
  base_url: {{ config.control_service.base_url }}
  api_key: "{{ bytefreezer_api_key }}"
  timeout_seconds: {{ config.control_service.timeout_seconds }}
  account_id: {{ config.control_service.account_id | default('') }}
  tenant_id: "{{ config.control_service.tenant_id | default('') }}"

# Parser configuration for log parsing (Logstash-style)
parsers:
  enabled: {{ config.parsers.enabled | lower }}
  load_defaults: {{ config.parsers.load_defaults | lower }}
  settings:
    max_line_length: {{ config.parsers.settings.max_line_length }}
    buffer_size: {{ config.parsers.settings.buffer_size }}
    parse_timeout_seconds: {{ config.parsers.settings.parse_timeout_seconds }}
    max_parse_errors: {{ config.parsers.settings.max_parse_errors }}
    grok_patterns_dir: {{ config.parsers.settings.grok_patterns_dir }}
  auto_tenant_parsers: {{ config.parsers.auto_tenant_parsers | lower }}
  format_defaults:
    plaintext:
{% for item in config.parsers.format_defaults.plaintext %}
      - type: {{ item.type }}
        config:
{% for key, value in item.config.items() %}
          {{ key }}: {{ value | lower if value is boolean else value }}
{% endfor %}
{% endfor %}
    syslog:
{% for item in config.parsers.format_defaults.syslog %}
      - type: {{ item.type }}
        config:
{% for key, value in item.config.items() %}
          {{ key }}: {{ value | lower if value is boolean else value }}
{% endfor %}
{% endfor %}
    ndjson:
{% for item in config.parsers.format_defaults.ndjson %}
      - type: {{ item.type }}
        config:
{% for key, value in item.config.items() %}
          {{ key }}: {{ value | lower if value is boolean else value }}
{% endfor %}
{% endfor %}
    json:
{% for item in config.parsers.format_defaults.json %}
      - type: {{ item.type }}
        config:
{% for key, value in item.config.items() %}
          {{ key }}: {{ value | lower if value is boolean else value }}
{% endfor %}
{% endfor %}

# Monitoring and observability
monitoring:
  metrics_port: {{ config.monitoring.metrics_port }}
  log_level: {{ config.monitoring.log_level }}
  enable_tracing: {{ config.monitoring.enable_tracing | lower }}

# Secrets management
secrets:
  provider: {{ config.secrets.provider }}
  region: {{ config.secrets.region }}

# Housekeeping configuration
housekeeping:
  enabled: {{ config.housekeeping.enabled | lower }}
  intervalseconds: {{ config.housekeeping.intervalseconds }}

# SOC configuration
soc:
  enabled: {{ config.soc.enabled | lower }}

# Health reporting configuration (uses control_service.base_url)
health_reporting:
  enabled: {{ config.health_reporting.enabled | default(true) | lower }}
  report_interval: {{ config.health_reporting.report_interval | default(30) }}
  timeout_seconds: {{ config.health_reporting.timeout_seconds | default(10) }}
  register_on_startup: {{ config.health_reporting.register_on_startup | default(true) | lower }}

# Error tracking configuration
error_tracking:
  enabled: {{ config.error_tracking.enabled | default(true) | lower }}

# Development mode
dev: {{ config.dev | lower }}